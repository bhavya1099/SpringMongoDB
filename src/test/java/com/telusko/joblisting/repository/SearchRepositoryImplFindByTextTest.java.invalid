package com.telusko.joblisting.repository;import com.mongodb.client.AggregateIterable;
import com.mongodb.client.MongoClient;
import com.mongodb.client.MongoCollection;
import com.mongodb.client.MongoDatabase;
import com.telusko.joblisting.model.Post;
import org.bson.Document;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.mongodb.core.convert.MongoConverter;
import org.springframework.stereotype.Component;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.Iterator;
import java.util.List;
import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;

class SearchRepositoryImplFindByTextTest {
    @Mock
    private MongoClient client;
    @Mock
    private MongoConverter converter;
    @InjectMocks
    private SearchRepositoryImpl searchRepository;
    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }
    @Test
    @Tag("valid")
    public void returnsPostsForValidText() {
        MongoDatabase database = mock(MongoDatabase.class);
        MongoCollection<Document> collection = mock(MongoCollection.class);
        AggregateIterable<Document> result = mock(AggregateIterable.class);
        Post post = new Post();
        List<Post> expectedPosts = Arrays.asList(post, post, post, post, post);
        when(client.getDatabase(anyString())).thenReturn(database);
        when(database.getCollection(anyString())).thenReturn(collection);
        when(collection.aggregate(any())).thenReturn(result);
        Iterator<Document> documentIterator = mock(Iterator.class);
        when(result.iterator()).thenReturn(documentIterator);
        when(documentIterator.hasNext()).thenReturn(true, true, true, true, true, false);
        when(documentIterator.next()).thenReturn(new Document(), new Document(), new Document(), new Document(), new Document());
        when(converter.read(Post.class, any(Document.class))).thenReturn(post);
        List<Post> actualPosts = searchRepository.findByText("valid text");
        assertEquals(5, actualPosts.size());
        assertEquals(expectedPosts, actualPosts);
    }
    @Test
    @Tag("invalid")
    public void returnsEmptyListForEmptyText() {
        MongoDatabase database = mock(MongoDatabase.class);
        MongoCollection<Document> collection = mock(MongoCollection.class);
        AggregateIterable<Document> result = mock(AggregateIterable.class);
        when(client.getDatabase(anyString())).thenReturn(database);
        when(database.getCollection(anyString())).thenReturn(collection);
        when(collection.aggregate(any())).thenReturn(result);
        when(result.iterator()).thenReturn(new ArrayList<Document>().iterator());
        List<Post> actualPosts = searchRepository.findByText("");
        assertTrue(actualPosts.isEmpty());
    }
    @Test
    @Tag("invalid")
    public void returnsEmptyListForNoMatch() {
        MongoDatabase database = mock(MongoDatabase.class);
        MongoCollection<Document> collection = mock(MongoCollection.class);
        AggregateIterable<Document> result = mock(AggregateIterable.class);
        when(client.getDatabase(anyString())).thenReturn(database);
        when(database.getCollection(anyString())).thenReturn(collection);
        when(collection.aggregate(any())).thenReturn(result);
        when(result.iterator()).thenReturn(new ArrayList<Document>().iterator());
        List<Post> actualPosts = searchRepository.findByText("no match");
        assertTrue(actualPosts.isEmpty());
    }
    @Test
    @Tag("invalid")
    public void throwsExceptionForNullText() {
        assertThrows(IllegalArgumentException.class, () -> searchRepository.findByText(null));
    }
    @Test
    @Tag("valid")
    public void sortsResultsByExperience() {
        MongoDatabase database = mock(MongoDatabase.class);
        MongoCollection<Document> collection = mock(MongoCollection.class);
        AggregateIterable<Document> result = mock(AggregateIterable.class);
        Post post1 = new Post();
        Post post2 = new Post();
        List<Post> expectedPosts = Arrays.asList(post1, post2);
        when(client.getDatabase(anyString())).thenReturn(database);
        when(database.getCollection(anyString())).thenReturn(collection);
        when(collection.aggregate(any())).thenReturn(result);
        Iterator<Document> documentIterator = mock(Iterator.class);
        when(result.iterator()).thenReturn(documentIterator);
        when(documentIterator.hasNext()).thenReturn(true, true, false);
        when(documentIterator.next()).thenReturn(new Document(), new Document());
        when(converter.read(Post.class, any(Document.class))).thenReturn(post1, post2);
        List<Post> actualPosts = searchRepository.findByText("valid text");
        assertEquals(2, actualPosts.size());
        assertEquals(expectedPosts, actualPosts);
    }
    @Test
    @Tag("boundary")
    public void limitsResultsToFive() {
        MongoDatabase database = mock(MongoDatabase.class);
        MongoCollection<Document> collection = mock(MongoCollection.class);
        AggregateIterable<Document> result = mock(AggregateIterable.class);
        Post post = new Post();
        List<Post> expectedPosts = Arrays.asList(post, post, post, post, post);
        when(client.getDatabase(anyString())).thenReturn(database);
        when(database.getCollection(anyString())).thenReturn(collection);
        when(collection.aggregate(any())).thenReturn(result);
        Iterator<Document> documentIterator = mock(Iterator.class);
        when(result.iterator()).thenReturn(documentIterator);
        when(documentIterator.hasNext()).thenReturn(true, true, true, true, true, false);
        when(documentIterator.next()).thenReturn(new Document(), new Document(), new Document(), new Document(), new Document());
        when(converter.read(Post.class, any(Document.class))).thenReturn(post);
        List<Post> actualPosts = searchRepository.findByText("valid text");
        assertEquals(5, actualPosts.size());
    }
    @Test
    @Tag("integration")
    public void handlesLargeNumberOfDocuments() {
        MongoDatabase database = mock(MongoDatabase.class);
        MongoCollection<Document> collection = mock(MongoCollection.class);
        AggregateIterable<Document> result = mock(AggregateIterable.class);
        Post post = new Post();
        List<Post> expectedPosts = new ArrayList<>();
        for (int i = 0; i < 1000; i++) {
            expectedPosts.add(post);
        }
        when(client.getDatabase(anyString())).thenReturn(database);
        when(database.getCollection(anyString())).thenReturn(collection);
        when(collection.aggregate(any())).thenReturn(result);
        Iterator<Document> documentIterator = mock(Iterator.class);
        when(result.iterator()).thenReturn(documentIterator);
        when(documentIterator.hasNext()).thenReturn(true, true, true, true, false);
        when(documentIterator.next()).thenReturn(new Document(), new Document(), new Document(), new Document());
        when(converter.read(Post.class, any(Document.class))).thenReturn(post);
        long startTime = System.currentTimeMillis();
        List<Post> actualPosts = searchRepository.findByText("valid text");
        long endTime = System.currentTimeMillis();
        assertTrue(actualPosts.size() > 0);
        assertTrue(endTime - startTime < 1000); // TODO: Adjust the time limit as per the requirement
    }
